{
  "AzureAd": {
    "TenantId": "{m365-tenantid}",
    "ClientId": "{m365-app-registration}",
    "ClientSecret": "{m365-app-registration-secret}"
  },
  "Foundry": {
    "FoundryEndpoint": "https://{your-project-name}.services.ai.azure.com",
    "FoundryProject": "{your-project-name}",
    "ApiKey": "{your-foundry-api-key}"
  },
  "AISearchService": {
    "Endpoint": "https://{ai-index}.search.windows.net",
    "IndexName": "{ai-index}",
    "ApiKey": "{ai-index-api-key}"
  },
  "EmbeddingService": {
    "Endpoint": "https://{embedding-name}.openai.azure.com/",
    "Deployment": "text-embedding-ada-002",
    "ApiKey": "{embedding-api-key}"
  },
  "AzureOpenAI": {
    "Endpoint": "https://{openai-resource}.cognitiveservices.azure.com/",
    "ApiKey": "{openai-api-key}"
  }
}
